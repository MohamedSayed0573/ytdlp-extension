{
    "name": "tubesize",
    "version": "1.0.0",
    "description": "View file size data for YouTube videos across different quality levels.",
    "scripts": {
        "build": "esbuild popup.ts background.ts content.ts options.ts --bundle --platform=browser --target=chrome90 --format=iife --outdir=dist --minify --define:__API_URL__='\"https://api.mohammedsayed.dev\"'",
        "watch": "esbuild popup.ts background.ts content.ts options.ts --bundle --platform=browser --target=chrome90 --format=iife --outdir=dist --watch --define:__API_URL__='\"https://api.mohammedsayed.dev\"'",
        "pack": "pnpm run build && rm -rf extension.zip && zip -r extension.zip manifest.json popup.html options.html dist icons",
        "prettier:write": "pnpm prettier . --write",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathIgnorePatterns=test.mjs",
        "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --testPathIgnorePatterns=test.mjs"
    },
    "keywords": [],
    "author": "Mohamed Sayed",
    "license": "MIT",
    "type": "module",
    "dependencies": {
        "filesize": "^11.0.13",
        "ms": "^2.1.3"
    },
    "devDependencies": {
        "@types/chrome": "^0.1.37",
        "@types/jest": "^30.0.0",
        "@types/ms": "^2.1.0",
        "esbuild": "^0.27.3",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "jest-extended": "^7.0.0",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "typescript": "^5.9.3"
    }
}
