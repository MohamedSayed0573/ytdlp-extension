{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "node",
        "lib": ["DOM", "ES2022"],
        "allowJs": true,
        "checkJs": true,
        "strict": true,
        "types": ["chrome", "jest", "jest-extended", "node"],
        "skipLibCheck": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "noEmit": true,
        "noUnusedLocals": true
    },
    "include": ["./**/*.ts", "./**/*.js"],
    "exclude": ["node_modules", "dist", "test.js"]
}
