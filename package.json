{
    "name": "newextension",
    "version": "1.0.0",
    "description": "",
    "main": "index.ts",
    "scripts": {
        "build": "esbuild popup.ts background.ts content.ts --bundle --platform=browser --target=chrome90 --format=iife --outdir=dist --define:__API_URL__='\"https://api.mohammedsayed.dev\"'",
        "watch": "esbuild popup.ts background.ts content.ts --bundle --platform=browser --target=chrome90 --format=iife --outdir=dist --watch --define:__API_URL__='\"https://api.mohammedsayed.dev\"'",
        "pack": "npm run build && zip -r extension.zip manifest.json popup.html background.ts content.ts dist"
    },
    "keywords": [],
