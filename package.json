    "type": "commonjs",
    "dependencies": {
        "ms": "^2.1.3"
    },
    "devDependencies": {
        "@types/chrome": "^0.1.37",
        "@types/ms": "^2.1.0",
        "esbuild": "^0.27.3",
        "typescript": "^5.9.3"
    }
}
