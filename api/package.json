{
    "name": "api",
    "version": "1.0.0",
    "description": "Backend API for the TubeSize Chrome extension, providing endpoint to fetch file size data for YouTube videos across different quality levels.",
    "main": "dist/server.js",
    "scripts": {
        "build": "npx tsc",
        "start": "pnpm run build && node dist/server.js",
        "dev": "nodemon --watch '**/*.ts' --exec 'npx tsc && node --inspect=0.0.0.0:9229 dist/server.js' | pino-pretty",
        "prettier:write": "pnpm prettier . --write"
    },
    "keywords": [],
    "author": "Mohamed Sayed",
    "license": "MIT",
    "type": "module",
    "dependencies": {
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^17.2.4",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "filesize": "^11.0.13",
        "helmet": "^8.1.0",
        "ms": "^2.1.3",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "redis": "^5.11.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/ms": "^2.1.0",
        "@types/pino": "^7.0.4",
        "@types/pino-http": "^5.8.4",
        "@types/pino-pretty": "^4.7.5",
        "@types/swagger-ui-express": "^4.1.8",
        "husky": "^9.1.7",
        "nodemon": "^3.1.11",
        "pino-pretty": "^13.1.3",
        "swagger-ui-express": "^5.0.1",
        "typescript": "^5.9.3"
    }
}
