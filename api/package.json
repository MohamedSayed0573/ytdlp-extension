{
    "name": "api",
    "version": "1.0.0",
    "description": "Backend API for the TubeSize Chrome extension, providing endpoint to fetch file size data for YouTube videos across different quality levels.",
    "main": "dist/server.js",
    "scripts": {
        "build": "npx tsc",
        "start": "pnpm run build && node dist/server.js",
        "dev": "nodemon --watch '**/*.ts' --exec 'npx tsc && node --inspect=0.0.0.0:9229 dist/server.js' | pino-pretty",
        "prettier:write": "pnpm prettier . --write"
    },
    "keywords": [],
    "author": "Mohamed Sayed",
    "license": "MIT",
    "type": "module",
    "dependencies": {
        "@fastify/compress": "^8.3.1",
        "@fastify/cors": "^11.2.0",
        "@fastify/helmet": "^13.0.2",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.5",
        "dotenv": "^17.2.4",
        "fastify": "^5.8.2",
        "filesize": "^11.0.13",
        "ms": "^2.1.3",
        "pino": "^10.3.1",
        "redis": "^5.11.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/ms": "^2.1.0",
        "@types/pino-pretty": "^4.7.5",
        "husky": "^9.1.7",
        "nodemon": "^3.1.11",
        "pino-pretty": "^13.1.3",
        "typescript": "^5.9.3"
    }
