{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "noEmit": false,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "target": "es2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "noUnusedLocals": true
    },
    "include": ["./**/*.ts", "./**/*.js"],
    "exclude": ["node_modules", "dist", "test.js"]
}
